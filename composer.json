{
    "name": "tahamiskini/crudify",
    "description": "Generic CRUD controller for Laravel.",
    "keywords": ["crudify", "laravel-crud", "laravel"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Taha",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-query-builder": "^6.0|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Taha\\Crudify\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Taha\\Crudify\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Taha\\Crudify\\CrudifyServiceProvider"
            ]
        }
    }
}