{
    "name": "tahamiskini/crudify-example",
    "type": "project",
    "description": "Example Laravel app demonstrating Crudify package usage.",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "tahamiskini/crudify": "*"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
